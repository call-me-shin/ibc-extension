{
  "manifest_version": 3,
  "name": "IBC – Information Bias Checker",
  "version": "0.1.0",
  "description": "Xのタイムラインにおけるフィルターバブル・エコーチェンバーを可視化します",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "src/content/collector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "IBC – バイアスをチェック"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/dashboard/dashboard.html",
        "src/dashboard/dashboard.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}